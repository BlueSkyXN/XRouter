{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "xrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "XRouter Local",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "apiKey": "{env:XROUTER_CLIENT_KEY}",
        "headers": {
          "x-session-id": "opencode-local"
        }
      },
      "models": {
        "xrouter/auto": {
          "name": "XRouter Auto"
        },
        "gpt-4o-mini": {
          "name": "XRouter Direct Alias"
        },
        "xrouter/code/go": {
          "name": "XRouter Code Router"
        },
        "xrouter/mov/parallel-synth": {
          "name": "XRouter Parallel Synthesis"
        },
        "xrouter/race/boundary-guard": {
          "name": "XRouter Boundary Guard Race"
        }
      }
    }
  },
  "model": "xrouter/xrouter/auto"
}
