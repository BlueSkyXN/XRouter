{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "xrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "XRouter Local",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "apiKey": "{env:XROUTER_CLIENT_KEY}",
        "headers": {
          "x-session-id": "opencode-local"
        }
      },
      "models": {
        "xrouter/auto": {
          "name": "XRouter Auto"
        },
        "xrouter/auto-single": {
          "name": "XRouter Auto Single"
        },
        "xrouter/auto-observed": {
          "name": "XRouter Auto Observed"
        },
        "xrouter/moa-balanced": {
          "name": "XRouter MoA Balanced"
        },
        "xrouter/fast": {
          "name": "XRouter Fast"
        }
      }
    }
  },
  "model": "xrouter/xrouter/auto"
}
